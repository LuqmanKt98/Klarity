{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information, preferences, and onboarding data.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "onboardingComplete": { "type": "boolean", "description": "Whether the user has completed onboarding" },
        "onboardingData": {
          "type": "object",
          "properties": {
            "primaryFocus": { "type": "string", "description": "Main reason for using the app" },
            "historyOfTherapy": { "type": "string", "description": "Previous therapy experience" },
            "currentStressLevel": { "type": "integer", "description": "Self-reported stress level 1-10" },
            "goals": { "type": "array", "items": { "type": "string" }, "description": "User's mental health goals" },
            "termsAccepted": { "type": "boolean", "description": "Whether the user accepted the legal disclaimers" }
          },
          "required": ["termsAccepted"]
        },
        "preferences": {
          "type": "object",
          "properties": {
            "modalities": { "type": "array", "items": { "type": "string" } },
            "intensityLevel": { "type": "string" },
            "morningCheckIn": { "type": "boolean" },
            "morningCheckInTime": { "type": "string" }
          }
        },
        "lastCheckInDate": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "onboardingComplete"]
    },
    "ChatThread": {
      "title": "Chat Thread",
      "description": "A conversation thread between the user and the AI.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string", "description": "Owner UID" },
        "title": { "type": "string" },
        "themeLabel": { "type": "string" },
        "createdAt": { "type": "integer" },
        "updatedAt": { "type": "integer" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "role": { "type": "string", "enum": ["user", "ai"] },
              "content": { "type": "string" },
              "timestamp": { "type": "integer" },
              "inferredMoodScore": { "type": "number" }
            }
          }
        }
      },
      "required": ["id", "uid", "title", "messages"]
    },
    "Affirmation": {
      "title": "Affirmation",
      "description": "User's saved affirmations or mantras.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "text": { "type": "string" },
        "categoryTags": { "type": "array", "items": { "type": "string" } },
        "isFavorite": { "type": "boolean" },
        "source": { "type": "string" }
      },
      "required": ["id", "uid", "text"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile document"
    },
    "/threads/{threadId}": {
      "schema": "ChatThread",
      "description": "Chat threads for the user"
    },
    "/affirmations/{affirmationId}": {
      "schema": "Affirmation",
      "description": "User's saved affirmations"
    }
  }
}
